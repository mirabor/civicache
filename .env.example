# .env.example — committed template. Copy to .env and fill in real values.
# .env is gitignored (see .gitignore:45); never commit it.

# Required by scripts/collect_trace.py (Congress.gov v3 API).
# Get a key at https://api.congress.gov/sign-up/.
CONGRESS_API_KEY=

# Required by scripts/pilot_court_trace.py (Phase 1) and
# scripts/collect_court_trace.py (Phase 3). CourtListener v4 API.
# Get a token at https://www.courtlistener.com/profile/
# after creating a free account at https://www.courtlistener.com/sign-up/.
COURTLISTENER_API_KEY=
